# BuildCycle Environment Configuration
# Copy this file to .env and fill in your values

# === Database ===
DATABASE_URL=postgres://buildcycle:buildcycle@localhost:5432/buildcycle

# === Backend ===
PORT=3001
JWT_SECRET=change-this-to-a-random-secret

# === Stellar / Soroban ===
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_ACCOUNT=

# Contract IDs (set after running scripts/deploy-contracts.sh)
BATCH_TOKEN_ID=
ESCROW_ID=
COMMUNITY_POOL_ID=

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_BATCH_TOKEN_ID=
NEXT_PUBLIC_ESCROW_ID=
NEXT_PUBLIC_COMMUNITY_POOL_ID=

# === IPFS (Pinata) ===
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# === Indexer ===
INDEXER_START_LEDGER=1
